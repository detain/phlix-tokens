{
  "name": "@phlix/tokens",
  "version": "0.1.1",
  "description": "Framework-agnostic design tokens for Phlix — single source of truth for theme tokens across web (phlix-ui, windows, tizen) and non-CSS clients (React Native, Roku). No Vue/Pinia/vue-router.",
  "type": "module",
  "main": "./dist/phlix-tokens.umd.cjs",
  "module": "./dist/phlix-tokens.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/phlix-tokens.js",
      "require": "./dist/phlix-tokens.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./css/*": "./dist/css/*",
    "./tokens.json": "./dist/tokens.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/css"
  ],
  "scripts": {
    "generate": "node scripts/generate-tokens.mjs",
    "build": "npm run generate && tsc --noEmit -p tsconfig.json && vite build && tsc --declaration --emitDeclarationOnly -p tsconfig.build.json && node scripts/build-css.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "github:detain/phlix-tokens"
  },
  "author": "detain",
  "keywords": [
    "phlix",
    "design-tokens",
    "tokens",
    "theme",
    "css-variables"
  ],
  "license": "MIT"
}
